@model TeamWare.Web.ViewModels.EditTaskViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="mx-auto max-w-lg">
    <div class="mb-2 text-sm text-gray-500 dark:text-gray-400">
        <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.ProjectId"
           class="hover:text-indigo-600 dark:hover:text-indigo-400">@Model.ProjectName</a>
        / <a asp-controller="Task" asp-action="Index" asp-route-projectId="@Model.ProjectId"
             class="hover:text-indigo-600 dark:hover:text-indigo-400">Tasks</a>
    </div>
    <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Edit Task</h1>

    <form asp-action="Edit" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ProjectId" />
        <input type="hidden" asp-for="ProjectName" />

        <div>
            <label asp-for="Title" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="Title" class="mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
            <span asp-validation-for="Title" class="mt-1 text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            @{ var editorModel = new MarkdownEditorViewModel { FieldName = "Description", Value = Model.Description }; }
            <partial name="_MarkdownEditor" model="editorModel" />
            <span asp-validation-for="Description" class="mt-1 text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="Priority" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                <select asp-for="Priority" asp-items="Html.GetEnumSelectList<TeamWare.Web.Models.TaskItemPriority>()"
                        class="mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                </select>
            </div>
            <div>
                <label asp-for="DueDate" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                <input asp-for="DueDate" type="date" class="mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 dark:text-red-400"></div>

        <div class="flex items-center justify-end gap-3">
            <a asp-action="Details" asp-route-id="@Model.Id" class="rounded-md px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700">Cancel</a>
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
