@model TeamWare.Web.ViewModels.TaskListViewModel
@{
    ViewData["Title"] = $"Tasks - {Model.ProjectName}";
}

<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.ProjectId"
               class="hover:text-indigo-600 dark:hover:text-indigo-400">@Model.ProjectName</a>
            <span>/</span>
            <span class="text-gray-900 dark:text-white">Tasks</span>
        </div>
        <h1 class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">Tasks</h1>
    </div>
    <a asp-action="Create" asp-route-projectId="@Model.ProjectId"
       class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
        New Task
    </a>
</div>

<!-- Filters -->
<div x-data="{ filtersOpen: false }" class="mb-6">
    <div class="flex flex-wrap items-center gap-3">
        <form method="get" class="flex flex-1 items-center gap-2">
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <input type="text" name="q" value="@Model.SearchQuery" placeholder="Search tasks..."
                   class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
            <button type="submit"
                    class="rounded-md bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
                Search
            </button>
        </form>
        <button @@click="filtersOpen = !filtersOpen"
                class="rounded-md bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
            Filters
        </button>
    </div>

    <div x-show="filtersOpen" x-cloak class="mt-3 rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <form method="get" class="flex flex-wrap items-end gap-4">
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400">Status</label>
                <select name="status" class="mt-1 rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                    <option value="">All</option>
                    <option value="@TeamWare.Web.Models.TaskItemStatus.ToDo" selected="@(Model.StatusFilter == TeamWare.Web.Models.TaskItemStatus.ToDo)">To Do</option>
                    <option value="@TeamWare.Web.Models.TaskItemStatus.InProgress" selected="@(Model.StatusFilter == TeamWare.Web.Models.TaskItemStatus.InProgress)">In Progress</option>
                    <option value="@TeamWare.Web.Models.TaskItemStatus.InReview" selected="@(Model.StatusFilter == TeamWare.Web.Models.TaskItemStatus.InReview)">In Review</option>
                    <option value="@TeamWare.Web.Models.TaskItemStatus.Done" selected="@(Model.StatusFilter == TeamWare.Web.Models.TaskItemStatus.Done)">Done</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400">Priority</label>
                <select name="priority" class="mt-1 rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                    <option value="">All</option>
                    <option value="@TeamWare.Web.Models.TaskItemPriority.Low" selected="@(Model.PriorityFilter == TeamWare.Web.Models.TaskItemPriority.Low)">Low</option>
                    <option value="@TeamWare.Web.Models.TaskItemPriority.Medium" selected="@(Model.PriorityFilter == TeamWare.Web.Models.TaskItemPriority.Medium)">Medium</option>
                    <option value="@TeamWare.Web.Models.TaskItemPriority.High" selected="@(Model.PriorityFilter == TeamWare.Web.Models.TaskItemPriority.High)">High</option>
                    <option value="@TeamWare.Web.Models.TaskItemPriority.Critical" selected="@(Model.PriorityFilter == TeamWare.Web.Models.TaskItemPriority.Critical)">Critical</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400">Assignee</label>
                <select name="assignee" class="mt-1 rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                    <option value="">All</option>
                    @foreach (var member in Model.ProjectMembers)
                    {
                        <option value="@member.UserId" selected="@(Model.AssigneeFilter == member.UserId)">@member.DisplayName</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400">Sort By</label>
                <select name="sortBy" class="mt-1 rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                    <option value="">Default</option>
                    <option value="priority" selected="@(Model.SortBy == "priority")">Priority</option>
                    <option value="duedate" selected="@(Model.SortBy == "duedate")">Due Date</option>
                    <option value="status" selected="@(Model.SortBy == "status")">Status</option>
                    <option value="title" selected="@(Model.SortBy == "title")">Title</option>
                </select>
            </div>
            <button type="submit"
                    class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">
                Apply
            </button>
            <a asp-action="Index" asp-route-projectId="@Model.ProjectId"
               class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
                Clear
            </a>
        </form>
    </div>
</div>

<!-- Task List -->
@if (!Model.Tasks.Any())
{
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center dark:border-gray-600">
        <p class="text-sm text-gray-500 dark:text-gray-400">
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                @:No tasks match your search.
            }
            else
            {
                @:No tasks yet. Create your first task to get started.
            }
        </p>
    </div>
}
else
{
    <div class="space-y-2">
        @foreach (var task in Model.Tasks)
        {
            var priorityClass = task.Priority switch
            {
                TeamWare.Web.Models.TaskItemPriority.Critical => "border-l-red-500",
                TeamWare.Web.Models.TaskItemPriority.High => "border-l-orange-500",
                TeamWare.Web.Models.TaskItemPriority.Medium => "border-l-blue-500",
                TeamWare.Web.Models.TaskItemPriority.Low => "border-l-gray-400",
                _ => "border-l-gray-400"
            };

            <a asp-action="Details" asp-route-id="@task.Id"
               class="block rounded-lg border border-l-4 border-gray-200 @priorityClass bg-white p-4 shadow-sm transition hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:hover:border-gray-600 @(task.IsOverdue ? "ring-1 ring-red-300 dark:ring-red-700" : "")">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2">
                            <h3 class="truncate text-sm font-medium text-gray-900 dark:text-white @(task.Status == TeamWare.Web.Models.TaskItemStatus.Done ? "line-through text-gray-500 dark:text-gray-400" : "")">
                                @task.Title
                            </h3>
                            @if (task.IsNextAction)
                            {
                                <span class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300">Next</span>
                            }
                            @if (task.IsSomedayMaybe)
                            {
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-400">Someday</span>
                            }
                        </div>
                        <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                            @{
                                var statusClass = task.Status switch
                                {
                                    TeamWare.Web.Models.TaskItemStatus.ToDo => "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300",
                                    TeamWare.Web.Models.TaskItemStatus.InProgress => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
                                    TeamWare.Web.Models.TaskItemStatus.InReview => "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300",
                                    TeamWare.Web.Models.TaskItemStatus.Done => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300",
                                    _ => ""
                                };
                                var statusText = task.Status switch
                                {
                                    TeamWare.Web.Models.TaskItemStatus.ToDo => "To Do",
                                    TeamWare.Web.Models.TaskItemStatus.InProgress => "In Progress",
                                    TeamWare.Web.Models.TaskItemStatus.InReview => "In Review",
                                    TeamWare.Web.Models.TaskItemStatus.Done => "Done",
                                    _ => ""
                                };
                            }
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @statusClass">@statusText</span>
                            @if (task.DueDate.HasValue)
                            {
                                <span class="@(task.IsOverdue ? "text-red-600 font-medium dark:text-red-400" : "")">
                                    Due @task.DueDate.Value.ToString("MMM d, yyyy")
                                </span>
                            }
                            @if (task.AssigneeNames.Any())
                            {
                                <span>@string.Join(", ", task.AssigneeNames)</span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        }
    </div>
}
