@model TeamWare.Web.ViewModels.WhiteboardInviteFormViewModel

<div class="space-y-4">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-md bg-green-50 px-3 py-2 text-sm text-green-700 dark:bg-green-900/20 dark:text-green-300">
            @Model.StatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-md bg-red-50 px-3 py-2 text-sm text-red-700 dark:bg-red-900/20 dark:text-red-300">
            @Model.ErrorMessage
        </div>
    }

    <div>
        <label for="whiteboard-invite-search" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Search Users</label>
        <input type="hidden" id="whiteboard-invite-whiteboard-id" name="whiteboardId" value="@Model.WhiteboardId" />
        <input type="text"
               id="whiteboard-invite-search"
               name="query"
               value="@Model.Query"
               placeholder="Type a name or email..."
               hx-get="@Url.Action("InviteForm", "Whiteboard")"
               hx-include="#whiteboard-invite-whiteboard-id"
               hx-target="#whiteboard-invite-form"
               hx-swap="innerHTML"
               hx-trigger="input changed delay:300ms, search"
               autocomplete="off"
               class="mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white" />
    </div>

    @if (Model.Candidates.Any())
    {
        <div class="max-h-64 space-y-2 overflow-y-auto rounded-md border border-gray-200 bg-gray-50 p-2 dark:border-gray-700 dark:bg-gray-900">
            @foreach (var candidate in Model.Candidates)
            {
                <div class="flex items-center justify-between gap-3 rounded-md bg-white px-3 py-2 shadow-sm dark:bg-gray-800">
                    <div class="min-w-0">
                        <p class="truncate text-sm font-medium text-gray-900 dark:text-gray-100">@candidate.DisplayName</p>
                        <p class="truncate text-xs text-gray-500 dark:text-gray-400">@candidate.Email</p>
                    </div>
                    @if (candidate.IsAlreadyInvited)
                    {
                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">
                            Already invited
                        </span>
                    }
                    else
                    {
                        <form hx-post="@Url.Action("Invite", "Whiteboard")"
                              hx-target="#whiteboard-invite-form"
                              hx-swap="innerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="whiteboardId" value="@Model.WhiteboardId" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="userIds" value="@candidate.UserId" />
                            <button type="submit"
                                    class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                                Invite
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.Query))
    {
        <p class="text-sm text-gray-500 dark:text-gray-400">No matching users found.</p>
    }

    <div class="border-t border-gray-200 pt-3 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">Already Invited</h3>
        @if (Model.InvitedUsers.Any())
        {
            <ul class="mt-2 space-y-2">
                @foreach (var invitedUser in Model.InvitedUsers)
                {
                    <li class="flex items-center justify-between gap-3 rounded-md bg-gray-50 px-3 py-2 text-sm dark:bg-gray-900">
                        <span class="text-gray-900 dark:text-gray-100">@invitedUser.UserDisplayName</span>
                        <span class="text-xs text-gray-500 dark:text-gray-400">@Html.LocalTime(invitedUser.CreatedAt, "short-datetime")</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No invitations have been sent yet.</p>
        }
    </div>
</div>
