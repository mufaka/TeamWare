@model TeamWare.Web.ViewModels.WhiteboardSessionViewModel
@{
    ViewData["Title"] = Model.Whiteboard.Title;

    var inactiveToolClass = "whiteboard-tool rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300";
    var tbBtnClass = "rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600 inline-flex items-center gap-1.5 whitespace-nowrap transition";
    var tbBtnActiveClass = "rounded-md bg-indigo-600 border border-indigo-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm inline-flex items-center gap-1.5 whitespace-nowrap transition";
    var tbBtnDangerClass = "rounded-md border border-red-300 bg-white px-3 py-1.5 text-sm font-medium text-red-700 shadow-sm hover:bg-red-50 dark:border-red-700 dark:bg-gray-700 dark:text-red-400 dark:hover:bg-red-900/20 inline-flex items-center gap-1.5 whitespace-nowrap transition";
}

<div class="space-y-6"
     data-whiteboard-session
     data-whiteboard-id="@Model.Whiteboard.Id"
     data-current-user-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
     data-is-owner="@Model.IsOwner.ToString().ToLowerInvariant()"
     data-is-presenter="@Model.IsPresenter.ToString().ToLowerInvariant()"
     data-is-temporary="@Model.IsTemporary.ToString().ToLowerInvariant()"
     data-can-draw="@Model.CanDraw.ToString().ToLowerInvariant()"
     data-landing-url="@Url.Action("Index", "Whiteboard")">

    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Whiteboard.Title</h1>
            <div class="mt-2 flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
                <span>Owner: <strong class="text-gray-900 dark:text-gray-100">@Model.Whiteboard.OwnerDisplayName</strong></span>
                <span>Presenter: <strong id="whiteboard-presenter-name" class="text-gray-900 dark:text-gray-100">@(Model.Whiteboard.CurrentPresenterDisplayName ?? "Unassigned")</strong></span>
                <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
                    @(Model.IsTemporary ? "Temporary board" : $"Saved to {Model.Whiteboard.ProjectName}")
                </span>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-2">
            @if (Model.IsOwner)
            {
                <button type="button"
                        onclick="window.whiteboardSession && window.whiteboardSession.reclaimPresenter()"
                        class="inline-flex items-center rounded-md border border-indigo-300 bg-white px-3 py-2 text-sm font-medium text-indigo-700 shadow-sm hover:bg-indigo-50 dark:border-indigo-700 dark:bg-gray-700 dark:text-indigo-300 dark:hover:bg-indigo-900/20">
                    Reclaim Presenter
                </button>
                <button type="button"
                        hx-get="@Url.Action("InviteForm", "Whiteboard", new { whiteboardId = Model.Whiteboard.Id })"
                        hx-target="#whiteboard-invite-form"
                        hx-swap="innerHTML"
                        class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300">
                    Invite Users
                </button>
            }

            @if (Model.IsOwner || Model.IsSiteAdmin)
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Whiteboard.Id" />
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-300 bg-white px-3 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-red-50 dark:border-red-700 dark:bg-gray-700 dark:text-red-400 dark:hover:bg-red-900/20"
                            onclick="return confirm('Are you sure you want to permanently delete this whiteboard? This action cannot be undone.')">
                        Delete
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem]">
        <div class="space-y-4">
            <div class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
                @* ── JointJS Toolbar ────────────────────────────────────── *@
                <div class="flex flex-wrap items-center gap-1.5 border-b border-gray-200 px-3 py-2 dark:border-gray-700" style="user-select:none;">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">Mode</span>
                    <button type="button" class="@tbBtnActiveClass" data-whiteboard-mode="select">↖ Select</button>
                    <button type="button" class="@tbBtnClass" data-whiteboard-mode="draw">✏ Draw</button>
                    <button type="button" class="@tbBtnClass" data-whiteboard-mode="lasso">⬡ Lasso</button>

                    <span class="mx-1 h-6 w-px bg-gray-300 dark:bg-gray-600"></span>

                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">Pen</span>
                    <div class="relative inline-flex cursor-pointer items-center" title="Pen color">
                        <div id="pen-color-swatch" class="h-6 w-6 rounded border-2 border-gray-400 dark:border-gray-500" style="background:#374151;"></div>
                        <input type="color" id="pen-color-input" value="#374151" class="absolute inset-0 h-full w-full cursor-pointer opacity-0" />
                    </div>
                    <button type="button" class="@tbBtnActiveClass pen-size" data-width="2" title="Fine">
                        <svg width="26" height="14" viewBox="0 0 26 14"><line x1="2" y1="7" x2="24" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </button>
                    <button type="button" class="@tbBtnClass pen-size" data-width="4" title="Medium">
                        <svg width="26" height="14" viewBox="0 0 26 14"><line x1="2" y1="7" x2="24" y2="7" stroke="currentColor" stroke-width="4" stroke-linecap="round"/></svg>
                    </button>
                    <button type="button" class="@tbBtnClass pen-size" data-width="8" title="Thick">
                        <svg width="26" height="14" viewBox="0 0 26 14"><line x1="2" y1="7" x2="24" y2="7" stroke="currentColor" stroke-width="8" stroke-linecap="round"/></svg>
                    </button>

                    <span class="mx-1 h-6 w-px bg-gray-300 dark:bg-gray-600"></span>

                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">Shapes</span>
                    <button type="button" class="@tbBtnClass" id="btn-rect">
                        <span class="inline-block h-3 w-3 rounded-sm" style="background:#3b82f6"></span> Rectangle
                    </button>
                    <button type="button" class="@tbBtnClass" id="btn-circle">
                        <span class="inline-block h-3 w-3 rounded-full" style="background:#ec4899"></span> Circle
                    </button>
                    <button type="button" class="@tbBtnClass" id="btn-diamond">
                        <span class="inline-block h-2.5 w-2.5 rotate-45" style="background:#10b981"></span> Diamond
                    </button>
                    <button type="button" class="@tbBtnClass" id="btn-cylinder">
                        <span class="inline-block h-3 w-3" style="background:#f59e0b;border-radius:40% 40% 0 0/20%"></span> Cylinder
                    </button>
                    <button type="button" class="@tbBtnClass" id="btn-text">
                        <b class="text-sm leading-none">T</b> Text
                    </button>

                    <span class="mx-1 h-6 w-px bg-gray-300 dark:bg-gray-600"></span>

                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">Edit</span>
                    <button type="button" class="@tbBtnClass" id="btn-undo" disabled>↩ Undo</button>
                    <button type="button" class="@tbBtnClass" id="btn-redo" disabled>↪ Redo</button>
                    <button type="button" class="@tbBtnDangerClass" id="whiteboard-delete-button">✕ Delete</button>
                    <button type="button" class="@tbBtnDangerClass" id="btn-clear">⬛ Clear</button>

                    <span class="mx-1 h-6 w-px bg-gray-300 dark:bg-gray-600"></span>

                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">View</span>
                    <button type="button" class="@tbBtnClass" id="btn-zoom-in">＋</button>
                    <button type="button" class="@tbBtnClass" id="btn-zoom-out">－</button>
                    <button type="button" class="@tbBtnClass" id="btn-fit">⊡ Fit</button>

                    <span class="mx-1 h-6 w-px bg-gray-300 dark:bg-gray-600"></span>

                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 px-1">File</span>
                    <button type="button" class="@tbBtnClass" id="btn-export">↓ Export</button>
                    <button type="button" class="@tbBtnClass" id="btn-import">↑ Import</button>
                </div>

                @* ── JointJS Canvas Area ──────────────────────────────── *@
                <div class="relative overflow-hidden" style="height:32rem;">
                    <div id="whiteboard-canvas-joint" class="h-full w-full"></div>
                    <div id="interaction-block" class="absolute inset-0 z-10" style="pointer-events:none;"></div>
                    <svg id="draw-layer" xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute inset-0 z-[5] overflow-visible" width="100%" height="100%">
                        <g id="draw-vp"></g>
                    </svg>
                </div>

                @* ── Status bar ───────────────────────────────────────── *@
                <div class="flex items-center justify-between border-t border-gray-200 px-3 py-1.5 text-xs text-gray-500 dark:border-gray-700 dark:text-gray-400">
                    <span>Shift+drag to pan · Scroll to zoom · Double-click to rename · Hover → drag ports to connect</span>
                    <span id="whiteboard-status-msg" class="italic text-indigo-500 dark:text-indigo-400">Ready</span>
                </div>
            </div>

            @if (Model.IsOwner)
            {
                <div id="whiteboard-project-association">
                    @await Html.PartialAsync("_ProjectAssociation", Model.ProjectAssociation)
                </div>
            }
        </div>

        <aside class="space-y-4">
            @if (Model.IsOwner)
            {
                <div id="whiteboard-invite-form" class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    @await Html.PartialAsync("_InviteForm", new TeamWare.Web.ViewModels.WhiteboardInviteFormViewModel
                    {
                        WhiteboardId = Model.Whiteboard.Id,
                        InvitedUsers = Model.Whiteboard.Invitations.OrderBy(i => i.UserDisplayName).ToList()
                    })
                </div>
            }

            <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">Active Users</h2>
                <ul id="whiteboard-active-users" class="mt-3 space-y-2 text-sm text-gray-600 dark:text-gray-400">
                    @if (Model.Whiteboard.ActiveUsers.Any())
                    {
                        @foreach (var activeUser in Model.Whiteboard.ActiveUsers)
                        {
                            var isPresenterUser = activeUser == Model.Whiteboard.CurrentPresenterId;
                            <li data-user-id="@activeUser"
                                class="rounded-md border border-transparent px-3 py-2 @(Model.IsOwner ? "cursor-pointer hover:border-indigo-200 hover:bg-indigo-50 dark:hover:border-indigo-800 dark:hover:bg-indigo-900/20" : string.Empty)"
                                x-data="{ open: false }"
                                @@contextmenu.prevent="@(Model.IsOwner ? "open = true" : "")">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-gray-900 dark:text-gray-100">@activeUser</span>
                                    @if (isPresenterUser)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">Presenter</span>
                                    }
                                </div>
                                @if (Model.IsOwner)
                                {
                                    <div x-show="open" x-cloak @@click.outside="open = false"
                                         class="mt-2 rounded-md border border-gray-200 bg-white p-2 shadow-lg dark:border-gray-700 dark:bg-gray-800">
                                        @if (!isPresenterUser)
                                        {
                                            <button type="button"
                                                    class="flex w-full rounded-md px-3 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700"
                                                    @@click="window.whiteboardSession && window.whiteboardSession.assignPresenter('@activeUser'); open = false;">
                                                Make Presenter
                                            </button>
                                        }
                                        @if (Model.IsTemporary)
                                        {
                                            <button type="button"
                                                    class="flex w-full rounded-md px-3 py-2 text-left text-sm text-red-700 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20"
                                                    @@click="window.whiteboardSession && window.whiteboardSession.removeUser('@activeUser'); open = false;">
                                                Remove User
                                            </button>
                                        }
                                    </div>
                                }
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-gray-500 dark:text-gray-400">No active users yet.</li>
                    }
                </ul>
            </div>

            <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">Chat</h2>
                <div id="whiteboard-chat-messages" class="mt-3 max-h-80 min-h-32 overflow-y-auto rounded-md border border-gray-200 bg-gray-50 p-3 text-sm dark:border-gray-600 dark:bg-gray-900">
                    @if (Model.ChatMessages.Any())
                    {
                        @foreach (var message in Model.ChatMessages)
                        {
                            <div class="mb-3 rounded-md bg-white p-3 shadow-sm last:mb-0 dark:bg-gray-800" data-chat-message-id="@message.Id">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="font-medium text-gray-900 dark:text-gray-100">@message.UserDisplayName</span>
                                    <span class="text-xs text-gray-500 dark:text-gray-400">@Html.LocalTime(message.CreatedAt, "short-datetime")</span>
                                </div>
                                <p class="mt-1 whitespace-pre-wrap text-gray-700 dark:text-gray-300">@message.Content</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-gray-500 dark:text-gray-400">No chat messages yet.</p>
                    }
                </div>
                <form id="whiteboard-chat-form" class="mt-3 space-y-2">
                    <label for="whiteboard-chat-input" class="sr-only">Chat message</label>
                    <textarea id="whiteboard-chat-input"
                              rows="3"
                              maxlength="4000"
                              class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white"
                              placeholder="Type a message..."></textarea>
                    <div class="flex items-center justify-between gap-3">
                        <span class="text-xs text-gray-500 dark:text-gray-400">Press Enter to send, Shift+Enter for a new line. Maximum 4000 characters.</span>
                        <button type="submit"
                                class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                            Send
                        </button>
                    </div>
                </form>
            </div>
        </aside>
    </div>
</div>

<script id="whiteboard-initial-canvas" type="application/json">@Html.Raw(Model.Whiteboard.CanvasData ?? "{\"cells\":[]}")</script>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@joint/core@4.2.4/dist/joint.css" />
    <script src="https://cdn.jsdelivr.net/npm/@@joint/core@4.2.4/dist/joint.min.js"></script>
    <script src="~/js/whiteboard-joint.js" asp-append-version="true"></script>
    <script src="~/js/whiteboard.js" asp-append-version="true"></script>
}
