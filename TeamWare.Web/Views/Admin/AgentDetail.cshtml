@model TeamWare.Web.ViewModels.AgentDetailViewModel
@{
    ViewData["Title"] = Model.DisplayName + " - Agent Details";
}

<div class="mx-auto max-w-5xl">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.DisplayName</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Agent Details</p>
        </div>
        <div class="flex gap-2">
            <a asp-action="EditAgent" asp-route-id="@Model.UserId"
               class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                Edit
            </a>
            <a asp-action="Agents" class="text-sm text-blue-600 hover:underline dark:text-blue-400 self-center">Back to Agents</a>
        </div>
    </div>

    @* Agent Profile Card *@
    <div class="mb-6 rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</p>
                <p class="mt-1">
                    @if (Model.IsAgentActive)
                    {
                        <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800 dark:bg-green-900 dark:text-green-200">Active</span>
                    }
                    else
                    {
                        <span class="inline-flex rounded-full bg-yellow-100 px-2 text-xs font-semibold leading-5 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">Paused</span>
                    }
                </p>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Last Active</p>
                <p class="mt-1 text-sm text-gray-900 dark:text-white">
                    @(Model.LastActiveAt.HasValue ? Model.LastActiveAt.Value.ToString("yyyy-MM-dd HH:mm UTC") : "Never")
                </p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.AgentDescription))
        {
            <div class="mt-4">
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Description</p>
                <p class="mt-1 text-sm text-gray-900 dark:text-white">@Model.AgentDescription</p>
            </div>
        }
    </div>

    @* Token newly generated *@
    @if (TempData["NewToken"] is string newToken)
    {
        <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 p-4 dark:border-amber-700 dark:bg-amber-900/20">
            <p class="mb-2 text-sm font-medium text-amber-800 dark:text-amber-200">New token generated. Copy it now — it will not be shown again.</p>
            <div class="flex gap-2">
                <input type="text" id="newTokenValue" value="@newToken" readonly
                       class="flex-1 rounded-lg border border-gray-300 bg-gray-50 px-4 py-2 font-mono text-sm text-gray-900 dark:border-gray-600 dark:bg-gray-800 dark:text-white" />
                <button type="button"
                        onclick="navigator.clipboard.writeText(document.getElementById('newTokenValue').value).then(function() { this.textContent = 'Copied'; }.bind(this))"
                        class="rounded-lg bg-gray-600 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700">
                    Copy
                </button>
            </div>
        </div>
    }

    @* PAT Section *@
    <div class="mb-6">
        <div class="mb-3 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">API Tokens</h2>
            <form asp-action="GenerateAgentToken" method="post">
                <input type="hidden" name="id" value="@Model.UserId" />
                <button type="submit"
                        class="rounded-lg bg-gray-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                    Generate New Token
                </button>
            </form>
        </div>

        @if (Model.Tokens.Count == 0)
        {
            <div class="rounded-lg border border-gray-200 bg-white p-4 text-center dark:border-gray-700 dark:bg-gray-800">
                <p class="text-sm text-gray-500 dark:text-gray-400">No active tokens.</p>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-800">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Name</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Prefix</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Created</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Last Used</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Status</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-900">
                        @foreach (var token in Model.Tokens)
                        {
                            <tr>
                                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900 dark:text-white">@token.Name</td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm font-mono text-gray-500 dark:text-gray-400">@token.TokenPrefix...</td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@token.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                                    @(token.LastUsedAt.HasValue ? token.LastUsedAt.Value.ToString("yyyy-MM-dd HH:mm") : "Never")
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm">
                                    @if (token.RevokedAt.HasValue)
                                    {
                                        <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800 dark:bg-red-900 dark:text-red-200">Revoked</span>
                                    }
                                    else if (token.ExpiresAt.HasValue && token.ExpiresAt < DateTime.UtcNow)
                                    {
                                        <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800 dark:bg-gray-700 dark:text-gray-300">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800 dark:bg-green-900 dark:text-green-200">Active</span>
                                    }
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                                    @if (!token.RevokedAt.HasValue)
                                    {
                                        <form asp-action="RevokeAgentToken" method="post" class="inline">
                                            <input type="hidden" name="userId" value="@Model.UserId" />
                                            <input type="hidden" name="tokenId" value="@token.Id" />
                                            <button type="submit" class="text-red-600 hover:underline dark:text-red-400">Revoke</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Project Memberships *@
    <div class="mb-6">
        <h2 class="mb-3 text-lg font-semibold text-gray-900 dark:text-white">Project Memberships</h2>

        @if (Model.ProjectMemberships.Count == 0)
        {
            <div class="rounded-lg border border-gray-200 bg-white p-4 text-center dark:border-gray-700 dark:bg-gray-800">
                <p class="text-sm text-gray-500 dark:text-gray-400">Not a member of any projects.</p>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-800">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Project</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Role</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-900">
                        @foreach (var membership in Model.ProjectMemberships)
                        {
                            <tr>
                                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900 dark:text-white">
                                    <a asp-controller="Project" asp-action="Details" asp-route-id="@membership.ProjectId" class="hover:underline">@membership.ProjectName</a>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@membership.Role</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Recent Activity *@
    <div class="mb-6">
        <h2 class="mb-3 text-lg font-semibold text-gray-900 dark:text-white">Recent Activity</h2>

        @if (Model.RecentActivity.Count == 0)
        {
            <div class="rounded-lg border border-gray-200 bg-white p-4 text-center dark:border-gray-700 dark:bg-gray-800">
                <p class="text-sm text-gray-500 dark:text-gray-400">No activity recorded.</p>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-800">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Action</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Admin</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Details</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-900">
                        @foreach (var entry in Model.RecentActivity)
                        {
                            <tr>
                                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900 dark:text-white">@entry.Action</td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@entry.AdminDisplayName</td>
                                <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@entry.Details</td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
