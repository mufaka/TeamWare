@model TeamWare.Web.ViewModels.GlobalConfigurationListViewModel
@{
    ViewData["Title"] = "Global Configuration";
}

<div class="mx-auto max-w-5xl">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Global Configuration</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage system-wide settings</p>
        </div>
        <a asp-action="Dashboard" class="rounded-md px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700">Back to Dashboard</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 rounded-md bg-green-50 p-4 text-sm text-green-700 dark:bg-green-900/20 dark:text-green-400">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 rounded-md bg-red-50 p-4 text-sm text-red-700 dark:bg-red-900/20 dark:text-red-400">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Key</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Value</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Description</th>
                    <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Last Updated</th>
                    <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-900">
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900 dark:text-white">@item.Key</td>
                        <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-300">
                            <span class="inline-block max-w-xs truncate" title="@item.Value">@item.Value</span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">@(item.Description ?? "-")</td>
                        <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                            <span>@item.UpdatedAt.ToString("g")</span>
                            @if (item.UpdatedByDisplayName != null)
                            {
                                <span class="ml-1 text-xs text-gray-400 dark:text-gray-500">by @item.UpdatedByDisplayName</span>
                            }
                        </td>
                        <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                            <a asp-action="EditConfiguration" asp-route-key="@item.Key"
                               class="font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300">Edit</a>
                        </td>
                    </tr>
                }

                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
                            No configuration entries found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
