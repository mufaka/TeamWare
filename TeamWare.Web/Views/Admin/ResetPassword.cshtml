@model TeamWare.Web.ViewModels.AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="mx-auto max-w-md">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Reset Password</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Set a new password for this user</p>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
        <div asp-validation-summary="All" class="mb-4 text-sm text-red-600 dark:text-red-400"></div>

        <form method="post" asp-action="ResetPassword" asp-route-id="@ViewData["UserId"]">
            <div class="mb-4">
                <label asp-for="Email" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                <input asp-for="Email" readonly
                       class="w-full rounded-lg border border-gray-300 bg-gray-50 px-4 py-2 text-sm text-gray-500 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-400" />
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                <input asp-for="NewPassword"
                       class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:focus:border-blue-400" />
                <span asp-validation-for="NewPassword" class="text-sm text-red-600 dark:text-red-400"></span>
            </div>

            <div class="mb-6">
                <label asp-for="ConfirmPassword" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                <input asp-for="ConfirmPassword"
                       class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:focus:border-blue-400" />
                <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600 dark:text-red-400"></span>
            </div>

            <div class="flex items-center justify-between">
                <a asp-action="Users" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Cancel</a>
                <button type="submit"
                        class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                    Reset Password
                </button>
            </div>
        </form>
    </div>
</div>
