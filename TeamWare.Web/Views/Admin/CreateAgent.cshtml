@model TeamWare.Web.ViewModels.CreateAgentViewModel
@{
    ViewData["Title"] = "Create Agent";
}

<div class="mx-auto max-w-2xl">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Create Agent</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Create a new agent user with an automatically generated API token.</p>
    </div>

    <div asp-validation-summary="All" class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400"></div>

    <form asp-action="CreateAgent" method="post" class="space-y-6">
        <div>
            <label asp-for="DisplayName" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="DisplayName"
                   class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-500 dark:focus:border-blue-400"
                   placeholder="e.g., Code Review Bot" />
            <span asp-validation-for="DisplayName" class="mt-1 text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <textarea asp-for="Description" rows="4"
                      class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-500 dark:focus:border-blue-400"
                      placeholder="Describe what this agent does..."></textarea>
            <span asp-validation-for="Description" class="mt-1 text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="rounded-lg bg-blue-600 px-6 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                Create
            </button>
            <a asp-action="Agents"
               class="rounded-lg border border-gray-300 px-6 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                Cancel
            </a>
        </div>
    </form>
</div>
