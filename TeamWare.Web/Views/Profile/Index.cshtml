@model TeamWare.Web.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="mx-auto max-w-2xl">
    <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">My Profile</h1>

    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="flex items-center gap-4">
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl" alt="Avatar" class="h-16 w-16 rounded-full object-cover" />
            }
            else
            {
                <div class="flex h-16 w-16 items-center justify-center rounded-full bg-indigo-100 text-xl font-bold text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400">
                    @(string.IsNullOrEmpty(Model.DisplayName) ? "?" : Model.DisplayName[0].ToString().ToUpper())
                </div>
            }
            <div>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@Model.DisplayName</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">@Model.Email</p>
            </div>
        </div>

        <dl class="mt-6 space-y-4">
            <div class="flex justify-between border-t border-gray-100 pt-4 dark:border-gray-700">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Display Name</dt>
                <dd class="text-sm text-gray-900 dark:text-white">@Model.DisplayName</dd>
            </div>
            <div class="flex justify-between border-t border-gray-100 pt-4 dark:border-gray-700">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Email</dt>
                <dd class="text-sm text-gray-900 dark:text-white">@Model.Email</dd>
            </div>
            <div class="flex justify-between border-t border-gray-100 pt-4 dark:border-gray-700">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Theme</dt>
                <dd class="text-sm text-gray-900 dark:text-white capitalize">@Model.ThemePreference</dd>
            </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-3 border-t border-gray-100 pt-6 dark:border-gray-700">
            <a asp-action="Edit"
               class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
                Edit Profile
            </a>
            <a asp-action="ChangePassword"
               class="inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
                Change Password
            </a>
        </div>
    </div>

    <!-- Theme Preference -->
    <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Theme Preference</h2>
        <form asp-action="UpdateTheme" method="post" hx-post="/Profile/UpdateTheme" hx-target="#theme-result" hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <div class="flex flex-wrap items-center gap-4">
                <label class="flex items-center gap-2">
                    <input type="radio" name="theme" value="light" class="text-indigo-600" @(Model.ThemePreference == "light" ? "checked" : "") />
                    <span class="text-sm text-gray-700 dark:text-gray-300">Light</span>
                </label>
                <label class="flex items-center gap-2">
                    <input type="radio" name="theme" value="dark" class="text-indigo-600" @(Model.ThemePreference == "dark" ? "checked" : "") />
                    <span class="text-sm text-gray-700 dark:text-gray-300">Dark</span>
                </label>
                <label class="flex items-center gap-2">
                    <input type="radio" name="theme" value="system" class="text-indigo-600" @(Model.ThemePreference == "system" ? "checked" : "") />
                    <span class="text-sm text-gray-700 dark:text-gray-300">System</span>
                </label>
                <button type="submit"
                        class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">
                    Save
                </button>
            </div>
            <div id="theme-result" class="mt-2 text-sm text-green-600 dark:text-green-400"></div>
        </form>
    </div>

    <!-- Personal Access Tokens -->
    @await Html.PartialAsync("_PersonalAccessTokens", (TeamWare.Web.ViewModels.PersonalAccessTokenListViewModel)ViewBag.TokenList)
</div>
