@model List<TeamWare.Web.ViewModels.ActivityLogEntryViewModel>

@if (Model.Any())
{
    <div class="flow-root">
        <ul class="-mb-4">
            @foreach (var entry in Model)
            {
                var iconClass = entry.ChangeType switch
                {
                    TeamWare.Web.Models.ActivityChangeType.Created => "bg-green-500",
                    TeamWare.Web.Models.ActivityChangeType.StatusChanged => "bg-blue-500",
                    TeamWare.Web.Models.ActivityChangeType.PriorityChanged => "bg-orange-500",
                    TeamWare.Web.Models.ActivityChangeType.Assigned => "bg-indigo-500",
                    TeamWare.Web.Models.ActivityChangeType.Unassigned => "bg-gray-500",
                    TeamWare.Web.Models.ActivityChangeType.Deleted => "bg-red-500",
                    _ => "bg-gray-400"
                };
                <li class="pb-4">
                    <div class="relative flex gap-3">
                        <div class="flex-shrink-0">
                            <span class="flex h-6 w-6 items-center justify-center rounded-full @iconClass">
                                <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 8 8">
                                    <circle cx="4" cy="4" r="3" />
                                </svg>
                            </span>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm text-gray-700 dark:text-gray-300">
                                @entry.Description
                                <a asp-controller="Task" asp-action="Details" asp-route-id="@entry.TaskItemId"
                                   class="font-medium text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300">@entry.TaskTitle</a>
                            </p>
                            <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">
                                @Html.LocalTime(entry.CreatedAt)
                            </p>
                        </div>
                    </div>
                </li>
            }
        </ul>
    </div>
}
else
{
    <p class="text-sm text-gray-500 dark:text-gray-400">No activity yet.</p>
}
