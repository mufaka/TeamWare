@model TeamWare.Web.ViewModels.ProjectDashboardViewModel
@{
    ViewData["Title"] = Model.Name;
    var isOwner = Model.CurrentUserRole == TeamWare.Web.Models.ProjectRole.Owner;
    var isOwnerOrAdmin = Model.CurrentUserRole == TeamWare.Web.Models.ProjectRole.Owner || Model.CurrentUserRole == TeamWare.Web.Models.ProjectRole.Admin;
}

<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mt-1 text-sm text-gray-600 dark:text-gray-400 markdown-body">@MarkdownHelper.RenderMarkdown(Model.Description)</div>
        }
        @if (Model.Status == TeamWare.Web.Models.ProjectStatus.Archived)
        {
            <span class="mt-2 inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                Archived
            </span>
        }
    </div>
    @if (isOwnerOrAdmin)
    {
        <div class="flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
                Edit
            </a>
            @if (isOwner && Model.Status == TeamWare.Web.Models.ProjectStatus.Active)
            {
                <form asp-action="Archive" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600"
                            onclick="return confirm('Are you sure you want to archive this project?')">
                        Archive
                    </button>
                </form>
            }
            @if (isOwner)
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit"
                            class="inline-flex items-center rounded-md border border-red-300 bg-white px-3 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-red-50 dark:border-red-700 dark:bg-gray-700 dark:text-red-400 dark:hover:bg-red-900/20"
                            onclick="return confirm('Are you sure you want to permanently delete this project? This action cannot be undone.')">
                        Delete
                    </button>
                </form>
            }
        </div>
    }
</div>

<!-- Task Stats Cards -->
<div class="mb-4 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Tasks</h2>
    <a asp-controller="Task" asp-action="Index" asp-route-projectId="@Model.Id"
       class="text-sm font-medium text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300">
        View all tasks
    </a>
</div>

@if (Model.TotalTasks > 0)
{
    <!-- Completion Progress Bar -->
    <div class="mb-4 rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <div class="mb-1 flex items-center justify-between text-sm">
            <span class="font-medium text-gray-700 dark:text-gray-300">Completion</span>
            <span class="font-semibold text-gray-900 dark:text-white">@Model.CompletionPercentage%</span>
        </div>
        <div class="h-2.5 w-full rounded-full bg-gray-200 dark:bg-gray-700">
            <div class="h-2.5 rounded-full bg-green-500 transition-all duration-300" style="width: @Model.CompletionPercentage%"></div>
        </div>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">@Model.TaskCountDone of @Model.TotalTasks tasks completed</p>
    </div>
}

<div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">To Do</p>
        <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">@Model.TaskCountToDo</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">In Progress</p>
        <p class="mt-1 text-2xl font-bold text-blue-600 dark:text-blue-400">@Model.TaskCountInProgress</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">In Review</p>
        <p class="mt-1 text-2xl font-bold text-yellow-600 dark:text-yellow-400">@Model.TaskCountInReview</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Done</p>
        <p class="mt-1 text-2xl font-bold text-green-600 dark:text-green-400">@Model.TaskCountDone</p>
    </div>
    @if (Model.OverdueTaskCount > 0)
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-700 dark:bg-red-900/20">
            <p class="text-sm font-medium text-red-600 dark:text-red-400">Overdue</p>
            <p class="mt-1 text-2xl font-bold text-red-700 dark:text-red-300">@Model.OverdueTaskCount</p>
        </div>
    }
</div>

<!-- Upcoming Deadlines -->
@if (Model.UpcomingDeadlines.Any())
{
    <div class="mb-8 rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800">
        <div class="border-b border-gray-200 px-5 py-4 dark:border-gray-700">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Upcoming Deadlines</h2>
        </div>
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
            @foreach (var deadline in Model.UpcomingDeadlines)
            {
                var daysText = deadline.DaysUntilDue switch
                {
                    0 => "Due today",
                    1 => "Due tomorrow",
                    _ => $"Due in {deadline.DaysUntilDue} days"
                };
                var urgencyClass = deadline.DaysUntilDue <= 1
                    ? "text-red-600 dark:text-red-400"
                    : "text-yellow-600 dark:text-yellow-400";
                <a asp-controller="Task" asp-action="Details" asp-route-id="@deadline.Id"
                   class="flex items-center justify-between px-5 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                    <div>
                        <p class="text-sm font-medium text-gray-900 dark:text-white">@deadline.Title</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400">@deadline.DueDate.ToString("MMM d, yyyy")</p>
                    </div>
                    <span class="text-xs font-medium @urgencyClass">@daysText</span>
                </a>
            }
        </div>
    </div>
}

<!-- Activity Timeline -->
<div class="mb-8 rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800">
    <div class="border-b border-gray-200 px-5 py-4 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Activity</h2>
    </div>
    <div class="p-5"
         hx-get="@Url.Action("ActivityTimeline", "Project", new { id = Model.Id })"
         hx-trigger="revealed"
         hx-swap="innerHTML">
        @await Html.PartialAsync("_ActivityTimeline", Model.RecentActivity)
    </div>
</div>

<!-- Members Section -->
<div class="rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800">
    <div class="flex items-center justify-between border-b border-gray-200 px-5 py-4 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            Members (@Model.TotalMembers)
        </h2>
        @if (isOwnerOrAdmin)
        {
            <div x-data="{ open: false }" class="relative">
                <button @@click="open = !open"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                    Invite
                </button>
                <div x-show="open" @@click.outside="open = false" x-cloak
                     class="absolute right-0 z-10 mt-2 w-80 rounded-md border border-gray-200 bg-white p-4 shadow-lg dark:border-gray-600 dark:bg-gray-700">
                    <form asp-action="InviteMember" method="post" class="space-y-3">
                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                        <div>
                            <label for="invite-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email Address</label>
                            <input type="email" name="Email" id="invite-email" required
                                   class="mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white" />
                        </div>
                        <button type="submit"
                                class="w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700">
                            Add Member
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="divide-y divide-gray-200 dark:divide-gray-700">
        @foreach (var member in Model.Members)
        {
            <div class="flex items-center justify-between px-5 py-3">
                <div class="flex items-center gap-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-indigo-100 text-sm font-medium text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400">
                        @member.DisplayName.FirstOrDefault().ToString().ToUpper()
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 dark:text-white">@member.DisplayName</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400">@member.Email</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    @if (member.Role == TeamWare.Web.Models.ProjectRole.Owner)
                    {
                        <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 dark:bg-purple-900/30 dark:text-purple-300">
                            Owner
                        </span>
                    }
                    else if (member.Role == TeamWare.Web.Models.ProjectRole.Admin)
                    {
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                            Admin
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                            Member
                        </span>
                    }

                    @if (isOwner && member.Role != TeamWare.Web.Models.ProjectRole.Owner)
                    {
                        <div x-data="{ open: false }" class="relative">
                            <button @@click="open = !open" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" aria-label="Member options">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                                </svg>
                            </button>
                            <div x-show="open" @@click.outside="open = false" x-cloak
                                 class="absolute right-0 z-10 mt-1 w-48 rounded-md border border-gray-200 bg-white py-1 shadow-lg dark:border-gray-600 dark:bg-gray-700">
                                @if (member.Role == TeamWare.Web.Models.ProjectRole.Member)
                                {
                                    <form asp-action="UpdateMemberRole" method="post">
                                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                                        <input type="hidden" name="UserId" value="@member.UserId" />
                                        <input type="hidden" name="Role" value="@TeamWare.Web.Models.ProjectRole.Admin" />
                                        <button type="submit" class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-600">
                                            Promote to Admin
                                        </button>
                                    </form>
                                }
                                else if (member.Role == TeamWare.Web.Models.ProjectRole.Admin)
                                {
                                    <form asp-action="UpdateMemberRole" method="post">
                                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                                        <input type="hidden" name="UserId" value="@member.UserId" />
                                        <input type="hidden" name="Role" value="@TeamWare.Web.Models.ProjectRole.Member" />
                                        <button type="submit" class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-600">
                                            Demote to Member
                                        </button>
                                    </form>
                                }
                                <form asp-action="RemoveMember" method="post">
                                    <input type="hidden" name="projectId" value="@Model.Id" />
                                    <input type="hidden" name="userId" value="@member.UserId" />
                                    <button type="submit"
                                            class="block w-full px-4 py-2 text-left text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20"
                                            onclick="return confirm('Remove this member from the project?')">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
