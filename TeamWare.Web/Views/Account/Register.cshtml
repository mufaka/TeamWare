@model TeamWare.Web.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="mx-auto max-w-md">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Register</h2>

    <form asp-action="Register" method="post" class="mt-6 space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 dark:text-red-400"></div>

        <div>
            <label asp-for="DisplayName" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="DisplayName" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="DisplayName" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="Email" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="Email" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="Email" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="Password" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="Password" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="Password" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="ConfirmPassword" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <button type="submit" class="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
            Register
        </button>
    </form>

    <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">
        Already have an account? <a asp-action="Login" class="text-blue-600 hover:underline dark:text-blue-400">Log in</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
