@{
    ViewData["Title"] = "Access Denied";
}

<div class="mx-auto max-w-md text-center">
    <h2 class="text-2xl font-bold text-red-600 dark:text-red-400">Access Denied</h2>
    <p class="mt-4 text-gray-600 dark:text-gray-400">You do not have permission to access this resource.</p>
    <a asp-controller="Home" asp-action="Index"
       class="mt-6 inline-block rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
        Return Home
    </a>
</div>
