@model TeamWare.Web.ViewModels.AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Reset User Password";
}

<div class="mx-auto max-w-md">
    <h2 class="text-2xl font-bold">Reset User Password</h2>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="mt-4 rounded-md bg-green-50 p-4 text-sm text-green-800 dark:bg-green-900/30 dark:text-green-300">
            @TempData["StatusMessage"]
        </div>
    }

    <form asp-action="ResetPassword" method="post" class="mt-6 space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 dark:text-red-400"></div>

        <div>
            <label asp-for="Email" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="Email" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="Email" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="NewPassword" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="NewPassword" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            <input asp-for="ConfirmPassword" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white sm:text-sm" />
            <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600 dark:text-red-400"></span>
        </div>

        <button type="submit" class="w-full rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
            Reset Password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
