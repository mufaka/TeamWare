@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-2xl font-bold text-red-600 dark:text-red-400">Error.</h1>
<h2 class="mt-2 text-lg text-red-600 dark:text-red-400">An error occurred while processing your request.</h2>

@if (Model.ShowRequestId)
{
    <p class="mt-4">
        <strong>Request ID:</strong> <code class="rounded bg-gray-100 px-2 py-1 text-sm dark:bg-gray-800">@Model.RequestId</code>
    </p>
}
