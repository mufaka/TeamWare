@model TeamWare.Web.ViewModels.ReviewTaskViewModel

<div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
            <a asp-controller="Task" asp-action="Details" asp-route-id="@Model.Id"
               class="font-medium text-gray-900 hover:text-indigo-600 dark:text-gray-100 dark:hover:text-indigo-400">
                @Model.Title
            </a>
            <div class="mt-1 flex flex-wrap items-center gap-2 text-xs">
                <span class="text-gray-500 dark:text-gray-400">@Model.ProjectName</span>
                <span class="rounded-full px-2 py-0.5 font-medium
                    @(Model.Status == TeamWare.Web.Models.TaskItemStatus.ToDo ? "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300" :
                      Model.Status == TeamWare.Web.Models.TaskItemStatus.InProgress ? "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300" :
                      Model.Status == TeamWare.Web.Models.TaskItemStatus.InReview ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300" :
                      "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300")">
                    @Model.Status
                </span>
                <span class="rounded-full px-2 py-0.5 font-medium
                    @(Model.Priority == TeamWare.Web.Models.TaskItemPriority.Low ? "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300" :
                      Model.Priority == TeamWare.Web.Models.TaskItemPriority.Medium ? "bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-300" :
                      Model.Priority == TeamWare.Web.Models.TaskItemPriority.High ? "bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-300" :
                      "bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-300")">
                    @Model.Priority
                </span>
                @if (Model.DueDate.HasValue)
                {
                    var isOverdue = Model.DueDate.Value < DateTime.UtcNow;
                    <span class="@(isOverdue ? "text-red-600 dark:text-red-400" : "text-gray-500 dark:text-gray-400")">
                        Due @Html.LocalTime(Model.DueDate.Value, "date")
                    </span>
                }
                @if (Model.IsNextAction)
                {
                    <span class="rounded-full bg-indigo-100 px-2 py-0.5 font-medium text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300">Next Action</span>
                }
                @if (Model.IsSomedayMaybe)
                {
                    <span class="rounded-full bg-purple-100 px-2 py-0.5 font-medium text-purple-700 dark:bg-purple-900/30 dark:text-purple-300">Someday/Maybe</span>
                }
            </div>
        </div>
        <a asp-controller="Task" asp-action="Details" asp-route-id="@Model.Id"
           class="shrink-0 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            View/Edit
        </a>
    </div>
</div>
