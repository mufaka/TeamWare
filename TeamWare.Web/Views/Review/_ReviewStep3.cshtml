@model TeamWare.Web.ViewModels.ReviewViewModel

<div class="space-y-6">
    <div>
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Step 3: Someday/Maybe</h2>
            <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 dark:bg-purple-900/30 dark:text-purple-300">
                @Model.SomedayMaybeItems.Count items
            </span>
        </div>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
            Review your Someday/Maybe items. Promote promising ones to active, keep them for later, or dismiss outdated items via task detail pages.
        </p>
    </div>

    @if (Model.SomedayMaybeItems.Count == 0)
    {
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-6 text-center dark:border-gray-700 dark:bg-gray-800">
            <p class="text-sm text-gray-500 dark:text-gray-400">No Someday/Maybe items to review.</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var item in Model.SomedayMaybeItems)
            {
                @await Html.PartialAsync("_ReviewTaskCard", item)
            }
        </div>
    }

    <!-- Complete Review -->
    <div class="mt-8 rounded-lg border border-indigo-200 bg-indigo-50 p-6 dark:border-indigo-800 dark:bg-indigo-900/20">
        <h3 class="text-lg font-semibold text-indigo-900 dark:text-indigo-200">Complete Your Review</h3>
        <p class="mt-1 text-sm text-indigo-700 dark:text-indigo-300">
            Add any notes about this review, then mark it as complete.
        </p>
        <form method="post" asp-controller="Review" asp-action="Complete" class="mt-4">
            <div class="mb-4">
                <label for="Notes" class="block text-sm font-medium text-indigo-800 dark:text-indigo-300">
                    Review Notes (optional)
                </label>
                <textarea name="Notes" id="Notes" rows="3"
                          maxlength="2000"
                          placeholder="What did you accomplish? What needs attention next week?"
                          class="mt-1 block w-full rounded-lg border border-indigo-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-indigo-500 dark:border-indigo-700 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-500"></textarea>
            </div>
            <button type="submit"
                    class="inline-flex items-center rounded-lg bg-indigo-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600">
                <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Complete Review
            </button>
        </form>
    </div>

    <!-- Navigation -->
    <div class="flex justify-start border-t border-gray-200 pt-4 dark:border-gray-700">
        <a hx-get="@Url.Action("Index", "Review", new { step = 2 })"
           hx-target="#review-step-content"
           hx-swap="innerHTML"
           hx-push-url="@Url.Action("Index", "Review", new { step = 2 })"
           class="inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 cursor-pointer">
            <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back: Active Tasks
        </a>
    </div>
</div>
