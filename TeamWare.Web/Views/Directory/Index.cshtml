@model TeamWare.Web.ViewModels.DirectoryListViewModel
@{
    ViewData["Title"] = "User Directory";
}

<div class="mx-auto max-w-5xl">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">User Directory</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">@Model.TotalCount registered users</p>
    </div>

    <form method="get" asp-action="Index" class="mb-6">
        <div class="flex gap-2">
            <input type="text" name="search" value="@Model.SearchTerm" placeholder="Search by name or email..."
                   class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-500 dark:focus:border-blue-400" />
            <button type="submit"
                    class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                Search
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-action="Index" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                    Clear
                </a>
            }
        </div>
    </form>

    @if (string.IsNullOrEmpty(Model.SearchTerm))
    {
        <div class="mb-4 flex items-center gap-4 text-sm">
            <span class="text-gray-500 dark:text-gray-400">Sort by:</span>
            @if (Model.SortBy == "displayname" && Model.Ascending)
            {
                <a asp-action="Index" asp-route-sortBy="displayname" asp-route-ascending="false"
                   class="font-medium text-blue-600 dark:text-blue-400">Name (A-Z)</a>
            }
            else if (Model.SortBy == "displayname" && !Model.Ascending)
            {
                <a asp-action="Index" asp-route-sortBy="displayname" asp-route-ascending="true"
                   class="font-medium text-blue-600 dark:text-blue-400">Name (Z-A)</a>
            }
            else
            {
                <a asp-action="Index" asp-route-sortBy="displayname" asp-route-ascending="true"
                   class="text-gray-700 hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400">Name</a>
            }
            <span class="text-gray-300 dark:text-gray-600">|</span>
            @if (Model.SortBy == "email" && Model.Ascending)
            {
                <a asp-action="Index" asp-route-sortBy="email" asp-route-ascending="false"
                   class="font-medium text-blue-600 dark:text-blue-400">Email (A-Z)</a>
            }
            else if (Model.SortBy == "email" && !Model.Ascending)
            {
                <a asp-action="Index" asp-route-sortBy="email" asp-route-ascending="true"
                   class="font-medium text-blue-600 dark:text-blue-400">Email (Z-A)</a>
            }
            else
            {
                <a asp-action="Index" asp-route-sortBy="email" asp-route-ascending="true"
                   class="text-gray-700 hover:text-blue-600 dark:text-gray-300 dark:hover:text-blue-400">Email</a>
            }
        </div>
    }

    @if (Model.Users.Count == 0)
    {
        <div class="rounded-lg border border-gray-200 bg-white p-8 text-center dark:border-gray-700 dark:bg-gray-800">
            <p class="text-gray-500 dark:text-gray-400">
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <text>No users found matching "@Model.SearchTerm".</text>
                }
                else
                {
                    <text>No users found.</text>
                }
            </p>
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var user in Model.Users)
            {
                <a asp-action="Profile" asp-route-id="@user.UserId"
                   class="block rounded-lg border border-gray-200 bg-white p-4 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:hover:border-gray-600">
                    <div class="flex items-center gap-3">
                        <div class="relative flex-shrink-0">
                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                            {
                                <img src="@user.AvatarUrl" alt="@user.DisplayName" class="h-10 w-10 rounded-full object-cover" />
                            }
                            else
                            {
                                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-100 text-sm font-medium text-blue-600 dark:bg-blue-900 dark:text-blue-300">
                                    @(string.IsNullOrEmpty(user.DisplayName) ? "?" : user.DisplayName[0].ToString().ToUpper())
                                </div>
                            }
                            <span data-presence-user="@user.UserId"
                                  class="absolute bottom-0 right-0 h-3 w-3 rounded-full border-2 border-white dark:border-gray-800 @(user.IsOnline ? "bg-green-500" : "bg-gray-400")"
                                  title="@(user.IsOnline ? "Online" : "Offline")"></span>
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="truncate text-sm font-medium text-gray-900 dark:text-white">@user.DisplayName</div>
                            <div class="truncate text-xs text-gray-500 dark:text-gray-400">@user.Email</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-6 flex items-center justify-between" aria-label="Pagination">
            <div class="text-sm text-gray-500 dark:text-gray-400">
                Page @Model.Page of @Model.TotalPages
            </div>
            <div class="flex gap-2">
                @if (Model.Page > 1)
                {
                    <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                       asp-route-ascending="@Model.Ascending" asp-route-page="@(Model.Page - 1)"
                       class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                        Previous
                    </a>
                }
                @if (Model.Page < Model.TotalPages)
                {
                    <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                       asp-route-ascending="@Model.Ascending" asp-route-page="@(Model.Page + 1)"
                       class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                        Next
                    </a>
                }
            </div>
        </nav>
    }
</div>
