@model List<TeamWare.Web.ViewModels.DashboardDeadlineViewModel>

@if (!Model.Any())
{
    <p class="text-sm text-gray-500 dark:text-gray-400">No upcoming deadlines.</p>
}
else
{
    <div class="space-y-2">
        @foreach (var deadline in Model)
        {
            var isOverdue = deadline.DueDate.Date < DateTime.UtcNow.Date && deadline.Status != TeamWare.Web.Models.TaskItemStatus.Done;
            var daysUntil = (deadline.DueDate.Date - DateTime.UtcNow.Date).Days;

            <a asp-controller="Task" asp-action="Details" asp-route-id="@deadline.TaskId"
               class="block rounded-lg bg-gray-50 p-3 transition hover:bg-gray-100 dark:bg-gray-800/50 dark:hover:bg-gray-700/50 @(isOverdue ? "ring-1 ring-red-300 dark:ring-red-700" : "")">
                <div class="flex items-center justify-between gap-2">
                    <div class="min-w-0 flex-1">
                        <h3 class="truncate text-sm font-medium text-gray-900 dark:text-white">@deadline.TaskTitle</h3>
                        <span class="text-xs text-indigo-600 dark:text-indigo-400">@deadline.ProjectName</span>
                    </div>
                    <div class="text-right text-xs">
                        @if (isOverdue)
                        {
                            <span class="font-medium text-red-600 dark:text-red-400">Overdue</span>
                        }
                        else if (daysUntil == 0)
                        {
                            <span class="font-medium text-orange-600 dark:text-orange-400">Due today</span>
                        }
                        else if (daysUntil == 1)
                        {
                            <span class="text-orange-600 dark:text-orange-400">Due tomorrow</span>
                        }
                        else
                        {
                            <span class="text-gray-500 dark:text-gray-400">@deadline.DueDate.ToString("MMM d")</span>
                        }
                    </div>
                </div>
            </a>
        }
    </div>
}
