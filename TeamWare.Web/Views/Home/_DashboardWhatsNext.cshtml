@model List<TeamWare.Web.ViewModels.WhatsNextItemViewModel>

@if (!Model.Any())
{
    <p class="text-sm text-gray-500 dark:text-gray-400">
        No Next Action tasks. Mark tasks as "Next Action" to see them here.
    </p>
}
else
{
    <div class="space-y-2">
        @foreach (var task in Model)
        {
            var priorityClass = task.Priority switch
            {
                TeamWare.Web.Models.TaskItemPriority.Critical => "border-l-red-500",
                TeamWare.Web.Models.TaskItemPriority.High => "border-l-orange-500",
                TeamWare.Web.Models.TaskItemPriority.Medium => "border-l-blue-500",
                TeamWare.Web.Models.TaskItemPriority.Low => "border-l-gray-400",
                _ => "border-l-gray-400"
            };

            <a asp-controller="Task" asp-action="Details" asp-route-id="@task.Id"
               class="block rounded-lg border border-l-4 border-gray-200 @priorityClass bg-gray-50 p-3 transition hover:bg-gray-100 dark:border-gray-700 dark:bg-gray-800/50 dark:hover:bg-gray-700/50 @(task.IsOverdue ? "ring-1 ring-red-300 dark:ring-red-700" : "")">
                <div class="flex items-center justify-between gap-2">
                    <div class="min-w-0 flex-1">
                        <h3 class="truncate text-sm font-medium text-gray-900 dark:text-white">@task.Title</h3>
                        <div class="mt-0.5 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                            <span class="text-indigo-600 dark:text-indigo-400">@task.ProjectName</span>
                            @if (task.DueDate.HasValue)
                            {
                                <span class="@(task.IsOverdue ? "text-red-600 font-medium dark:text-red-400" : "")">
                                    Due @Html.LocalTime(task.DueDate.Value, "short-date")
                                </span>
                            }
                        </div>
                    </div>
                    @{
                        var badgeClass = task.Priority switch
                        {
                            TeamWare.Web.Models.TaskItemPriority.Critical => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300",
                            TeamWare.Web.Models.TaskItemPriority.High => "bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300",
                            TeamWare.Web.Models.TaskItemPriority.Medium => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
                            TeamWare.Web.Models.TaskItemPriority.Low => "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300",
                            _ => ""
                        };
                        var statusBadgeClass = task.Status switch
                        {
                            TeamWare.Web.Models.TaskItemStatus.ToDo => "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300",
                            TeamWare.Web.Models.TaskItemStatus.InProgress => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
                            TeamWare.Web.Models.TaskItemStatus.InReview => "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300",
                            TeamWare.Web.Models.TaskItemStatus.Done => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300",
                            TeamWare.Web.Models.TaskItemStatus.Blocked => "bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300",
                            TeamWare.Web.Models.TaskItemStatus.Error => "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300",
                            _ => "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300"
                        };
                        var statusText = task.Status switch
                        {
                            TeamWare.Web.Models.TaskItemStatus.ToDo => "To Do",
                            TeamWare.Web.Models.TaskItemStatus.InProgress => "In Progress",
                            TeamWare.Web.Models.TaskItemStatus.InReview => "In Review",
                            TeamWare.Web.Models.TaskItemStatus.Done => "Done",
                            TeamWare.Web.Models.TaskItemStatus.Blocked => "Blocked",
                            TeamWare.Web.Models.TaskItemStatus.Error => "Error",
                            _ => "Unknown"
                        };
                    }
                    <div class="flex items-center gap-1.5">
                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @statusBadgeClass">@statusText</span>
                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @badgeClass">@task.Priority</span>
                    </div>
                </div>
            </a>
        }
    </div>
    <div class="mt-3 text-right">
        <a asp-controller="Home" asp-action="WhatsNext"
           class="text-sm font-medium text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300">
            View all &rarr;
        </a>
    </div>
}
