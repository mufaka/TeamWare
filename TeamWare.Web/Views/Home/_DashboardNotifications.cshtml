@model List<TeamWare.Web.ViewModels.DashboardNotificationViewModel>

@if (!Model.Any())
{
    <p class="text-sm text-gray-500 dark:text-gray-400">No new notifications.</p>
}
else
{
    <div class="space-y-2">
        @foreach (var notification in Model)
        {
            var iconClass = notification.Type switch
            {
                TeamWare.Web.Models.NotificationType.TaskAssigned => "text-blue-500",
                TeamWare.Web.Models.NotificationType.DeadlineApproaching => "text-orange-500",
                TeamWare.Web.Models.NotificationType.StatusChanged => "text-green-500",
                TeamWare.Web.Models.NotificationType.CommentAdded => "text-purple-500",
                TeamWare.Web.Models.NotificationType.InboxThreshold => "text-amber-500",
                _ => "text-gray-500"
            };

            <div class="flex items-start gap-3 rounded-lg bg-gray-50 p-3 dark:bg-gray-800/50">
                <div class="mt-0.5 @iconClass">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                        <circle cx="10" cy="10" r="4" />
                    </svg>
                </div>
                <div class="min-w-0 flex-1">
                    <p class="text-sm text-gray-700 dark:text-gray-300">@notification.Message</p>
                    <p class="mt-0.5 text-xs text-gray-400">@Html.LocalTime(notification.CreatedAt, "short-datetime")</p>
                </div>
            </div>
        }
    </div>
    <div class="mt-3 text-right">
        <a asp-controller="Notification" asp-action="Index"
           class="text-sm font-medium text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300">
            View all &rarr;
        </a>
    </div>
}
