@{
    ViewData["Title"] = "Dashboard";
}

<div class="mx-auto max-w-5xl">
    <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Dashboard</h1>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Inbox -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Inbox</h2>
            <div hx-get="/Home/DashboardInbox" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- Review Status -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Weekly Review</h2>
            <div hx-get="/Home/DashboardReview" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- What's Next -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 lg:col-span-2">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">What's Next</h2>
            <div hx-get="/Home/DashboardWhatsNext" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- Projects -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Projects</h2>
            <div hx-get="/Home/DashboardProjects" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- Upcoming Deadlines -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Upcoming Deadlines</h2>
            <div hx-get="/Home/DashboardDeadlines" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- Recent Notifications -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 lg:col-span-2">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Recent Notifications</h2>
            <div hx-get="/Home/DashboardNotifications" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>

        <!-- Global Activity Feed (ACTV-02) -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 lg:col-span-2">
            <h2 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Recent Activity</h2>
            <div hx-get="/Activity/GlobalFeed" hx-trigger="load" hx-swap="innerHTML">
                <div class="flex items-center justify-center py-4">
                    <span class="text-sm text-gray-400">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>
