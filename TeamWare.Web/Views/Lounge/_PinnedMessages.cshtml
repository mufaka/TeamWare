@model List<TeamWare.Web.ViewModels.LoungeMessageViewModel>

@if (Model.Count == 0)
{
    <p class="text-xs text-gray-400 dark:text-gray-500">No pinned messages.</p>
}
else
{
    @foreach (var message in Model)
    {
        <div class="mt-2 flex items-start gap-2 rounded bg-yellow-100/50 px-2 py-1 dark:bg-yellow-800/10" data-pinned-message-id="@message.Id">
            <div class="min-w-0 flex-1">
                <div class="flex items-baseline gap-2">
                    <span class="text-xs font-semibold text-gray-900 dark:text-white">@message.AuthorDisplayName</span>
                    <span class="text-xs text-gray-500 dark:text-gray-400">@message.CreatedAt.ToString("MMM dd, HH:mm")</span>
                </div>
                <p class="mt-0.5 text-xs text-gray-700 dark:text-gray-300 line-clamp-2">@message.Content</p>
            </div>
            @if (message.CanPin)
            {
                <form asp-action="UnpinMessage" asp-controller="Lounge" method="post" class="flex-shrink-0"
                      hx-post="@Url.Action("UnpinMessage", "Lounge")"
                      hx-target="#pinned-messages-list"
                      hx-swap="innerHTML">
                    <input type="hidden" name="messageId" value="@message.Id" />
                    <button type="submit" class="text-xs text-yellow-600 hover:text-yellow-800 dark:text-yellow-400 dark:hover:text-yellow-200"
                            title="Unpin">
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </form>
            }
        </div>
    }
}
