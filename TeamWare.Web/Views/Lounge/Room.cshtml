@model TeamWare.Web.ViewModels.LoungeRoomViewModel
@{
    ViewData["Title"] = Model.RoomName + " - Lounge";
    var projectIdAttr = Model.ProjectId.HasValue ? Model.ProjectId.Value.ToString() : "";
    var lastReadId = Model.LastReadMessageId?.ToString() ?? "";
    var membersJson = System.Text.Json.JsonSerializer.Serialize(Model.Members.Select(m => new { m.UserId, m.DisplayName, m.UserName }));
}

<div class="flex h-[calc(100vh-8rem)] flex-col" id="lounge-room"
     data-project-id="@projectIdAttr"
     data-last-read-id="@lastReadId">

    <!-- Room header -->
    <div class="flex items-center justify-between border-b border-gray-200 px-4 py-3 dark:border-gray-700">
        <h1 class="text-lg font-semibold text-gray-900 dark:text-white">@Model.RoomName</h1>
        <div class="flex items-center gap-2">
            <button id="btn-toggle-pinned" type="button"
                    class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700"
                    title="Toggle pinned messages">
                <svg class="inline-block h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
                Pinned
            </button>
        </div>
    </div>

    <!-- Pinned messages banner -->
    <div id="pinned-messages-area" class="hidden border-b border-yellow-200 bg-yellow-50 dark:border-yellow-700 dark:bg-yellow-900/20">
        <div class="px-4 py-2">
            <div class="flex items-center justify-between">
                <span class="text-xs font-medium text-yellow-700 dark:text-yellow-400">Pinned Messages</span>
                <button id="btn-close-pinned" type="button" class="text-yellow-600 hover:text-yellow-800 dark:text-yellow-400 dark:hover:text-yellow-200">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div id="pinned-messages-list" hx-get="@Url.Action("PinnedMessages", "Lounge", new { projectId = Model.ProjectId })" hx-trigger="load" hx-swap="innerHTML">
                @await Html.PartialAsync("_PinnedMessages", Model.PinnedMessages)
            </div>
        </div>
    </div>

    <!-- Scrollable message area -->
    <div id="message-area" class="flex-1 overflow-y-auto px-4 py-4" role="log" aria-label="Chat messages" aria-live="polite">
        <!-- Load older messages button -->
        <div id="load-older-area" class="mb-4 text-center">
            @if (Model.Messages.Count >= 50)
            {
                <button id="btn-load-older" type="button"
                        class="rounded-md bg-gray-100 px-4 py-2 text-sm text-gray-600 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
                    Load older messages
                </button>
            }
        </div>

        <!-- Messages list -->
        <div id="message-list">
            @await Html.PartialAsync("_MessageList", Model.Messages)
        </div>

        <!-- New messages divider (hidden by default, shown by JS) -->
        <div id="new-messages-divider" class="my-2 hidden items-center gap-2">
            <hr class="flex-1 border-red-400 dark:border-red-500" />
            <span class="text-xs font-medium text-red-500 dark:text-red-400">New messages</span>
            <hr class="flex-1 border-red-400 dark:border-red-500" />
        </div>
    </div>

    <!-- New messages indicator (shown when scrolled up) -->
    <div id="new-messages-indicator" class="hidden border-t border-blue-200 bg-blue-50 dark:border-blue-700 dark:bg-blue-900/20">
        <button type="button" id="btn-scroll-to-bottom"
                class="w-full px-4 py-2 text-center text-sm font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200">
            New messages below
        </button>
    </div>

    <!-- Message input -->
    <div class="border-t border-gray-200 px-4 py-3 dark:border-gray-700">
        <form id="message-form" class="flex gap-2">
            <div class="relative flex-1">
                <input type="text" id="message-input" name="content"
                       class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-500 dark:focus:border-blue-400"
                       placeholder="Type a message..."
                       autocomplete="off"
                       maxlength="4000"
                       aria-label="Message input" />
                <!-- Mention autocomplete dropdown -->
                <div id="mention-dropdown" class="absolute bottom-full left-0 z-50 mb-1 hidden max-h-48 w-64 overflow-y-auto rounded-lg border border-gray-200 bg-white shadow-lg dark:border-gray-600 dark:bg-gray-700"
                     role="listbox" aria-label="Mention suggestions">
                </div>
            </div>
            <button type="submit" id="btn-send"
                    class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:bg-blue-500 dark:hover:bg-blue-600"
                    aria-label="Send message">
                Send
            </button>
        </form>
    </div>
</div>

<!-- Edit message modal -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50" role="dialog" aria-modal="true" aria-label="Edit message">
    <div class="mx-4 w-full max-w-lg rounded-lg bg-white p-6 shadow-xl dark:bg-gray-800">
        <h3 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">Edit Message</h3>
        <input type="hidden" id="edit-message-id" />
        <textarea id="edit-message-content"
                  class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-700 dark:text-white"
                  rows="3" maxlength="4000"></textarea>
        <div class="mt-4 flex justify-end gap-2">
            <button type="button" id="btn-edit-cancel"
                    class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                Cancel
            </button>
            <button type="button" id="btn-edit-save"
                    class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600">
                Save
            </button>
        </div>
    </div>
</div>

<!-- Hidden form for CSRF token extraction -->
<form id="lounge-csrf-form" method="post" class="hidden">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        window.loungeMembers = @Html.Raw(membersJson);
    </script>
    <script src="~/js/lounge.js" asp-append-version="true"></script>
}
