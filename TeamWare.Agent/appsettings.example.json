{
  // TeamWare Agent Configuration
  // Copy this file to appsettings.json and fill in your values.
  // Sensitive values (PATs, access tokens) can also be set via environment variables
  // prefixed with TEAMWARE_AGENT_ (e.g., TEAMWARE_AGENT_Agents__0__PersonalAccessToken).

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting": "Information",
      "TeamWare.Agent": "Debug"
    }
  },

  // Each entry in the Agents array configures one agent identity.
  // Multiple identities can run in the same process, each polling independently.
  "Agents": [
    {
      // Display name for this agent identity (used in logs)
      "Name": "my-coding-agent",

      // Local directory where the agent works (clones repos, runs commands)
      "WorkingDirectory": "/path/to/working/directory",

      // (Optional) Git repository URL — if set, the agent will clone/pull before each task
      "RepositoryUrl": "https://github.com/your-org/your-repo.git",

      // (Optional) Branch to clone/pull from (default: "main")
      "RepositoryBranch": "main",

      // (Optional) Git access token for private repositories
      // This is inserted into the HTTPS URL for authentication
      "RepositoryAccessToken": "",

      // TeamWare Personal Access Token for MCP authentication (required)
      "PersonalAccessToken": "your-pat-token-here",

      // Seconds between polling cycles (default: 60)
      "PollingIntervalSeconds": 60,

      // (Optional) Copilot model to use (e.g., "gpt-4o") — uses SDK default if null
      "Model": null,

      // Auto-approve all tool calls (default: true)
      // Set to false to enable custom permission handling that blocks dangerous operations
      "AutoApproveTools": true,

      // Dry run mode — log write operations instead of executing them (default: false)
      // Recommended for initial setup and testing
      "DryRun": true,

      // (Optional) Custom system prompt — uses the built-in default if null
      // The default prompt instructs the agent to read, assess, change, test, commit, and report
      "SystemPrompt": null,

      // MCP server connections (at least one HTTP server pointing to TeamWare is required)
      "McpServers": [
        {
          "Name": "teamware",
          "Type": "http",
          "Url": "https://your-teamware-instance/mcp",
          // (Optional) Custom Authorization header — falls back to "Bearer {PAT}" if not set
          "AuthHeader": null
        }
      ]
    }
  ]
}
